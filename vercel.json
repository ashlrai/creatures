{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd creatures-web && npm run build",
  "outputDirectory": "creatures-web/dist",
  "installCommand": "cd creatures-web && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
